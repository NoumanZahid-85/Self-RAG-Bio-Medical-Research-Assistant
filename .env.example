# =============================================================================
# Self-RAG Biomedical Research Assistant — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it's in .gitignore for a reason.

# --- Groq API (LLM provider) ---
# Get your key at: https://console.groq.com/keys
# Free Developer tier: $0/month, card-gated, no minimum spend
GROQ_API_KEY="gsk_your_groq_api_key_here"

# --- PostgreSQL + pgvector ---
# Local Docker: postgresql://selfrag:selfrag@db:5432/selfrag
# When running ingest/scripts from your host (not inside Docker):
#   postgresql://selfrag:selfrag@localhost:5432/selfrag
DATABASE_URL=postgresql://selfrag:selfrag@localhost:5432/selfrag

# --- LangSmith Observability (https://smith.langchain.com) ---
# Set to "true" to enable auto-tracing of all LangGraph + LLM calls.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY="lsv2_your_langsmith_api_key_here"
LANGSMITH_PROJECT="Self-RAG Biomedical Research Assistant"

# --- Application Settings ---
# Set to "true" during load testing (Phase 10) to use MockLLMClient
# instead of real Groq calls — saves quota and lets you test infra only.
USE_MOCK_LLM=false

# Rate limiting: per-IP requests per minute (Phase 4)
RATE_LIMIT_PER_IP_RPM=5

# Global queue: max concurrent Groq API calls
GROQ_MAX_CONCURRENT=5
GROQ_RPM_BUDGET=25

# --- Jina Embeddings API ---
# Get your key at: https://jina.ai/embeddings/
# jina-embeddings-v3 dimension: 1024
JINA_API_KEY="jina_your_jina_api_key_here"

# --- Development vs Production ---
ENVIRONMENT=development
LOG_LEVEL=INFO
